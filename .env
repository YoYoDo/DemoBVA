CLAUDE_MEMORY_ENABLED=true
CLAUDE_MEMORY_PATH=.claude/memory
CLAUDE_SKILLS_PATH=.claude/skills
CLAUDE_WORKFLOWS_PATH=.claude/workflows
CLAUDE_COMMANDS_PATH=.claude/commands
CLAUDE_SPECIFY_PATH=.specify
CLAUDE_CONFIG_PATH=.claude/config

# 自動加載設置
CLAUDE_AUTOLOAD=true
CLAUDE_AUTOSAVE=true
CLAUDE_AUTO_INIT=true
CLAUDE_PRELOAD_COMMANDS=true
CLAUDE_PRELOAD_SPECIFY=true

# 初始化行為
CLAUDE_INIT_SCAN_SKILLS=true
CLAUDE_INIT_LOAD_WORKFLOWS=true
CLAUDE_INIT_LOAD_COMMANDS=true
CLAUDE_INIT_LOAD_SPECIFY=true
CLAUDE_INIT_RESTORE_CONTEXT=true
CLAUDE_INIT_CHECK_TASKS=true

# 記憶持久化
CLAUDE_MEMORY_AUTOSAVE_INTERVAL=5000
CLAUDE_MEMORY_BACKUP_ON_STARTUP=true
CLAUDE_MEMORY_RETENTION_DAYS=90

# 工作流設置
CLAUDE_WORKFLOW_AUTOSAVE=true
CLAUDE_WORKFLOW_VALIDATE_ON_LOAD=true
CLAUDE_WORKFLOW_TIMEOUT_MINUTES=30

# 日誌和調試
CLAUDE_LOG_LEVEL=info
CLAUDE_DEBUG=false
CLAUDE_VERBOSE_INIT=false

# 工作區設置
WORKSPACE_ROOT=/Users/user/Dev/SpecSkills
PROJECT_NAME=SpecSkills
PROJECT_TYPE=ai-assistant
